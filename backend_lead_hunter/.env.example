APIFY_TOKEN=your_apify_token
OPENAI_API_KEY=your_openai_api_key

# New bot only for leads. Existing TG_BOT_TOKEN is not used.
TG_LEAD_BOT=your_lead_bot_token
MY_CHAT_ID=your_telegram_chat_id

APIFY_INSTAGRAM_SEARCH_ACTOR=apify/instagram-search-scraper
APIFY_INSTAGRAM_PROFILE_ACTOR=apify/instagram-scraper
APIFY_INSTAGRAM_COMMENT_ACTOR=apify/instagram-comment-scraper

OPENAI_MODEL=gpt-4o
DRY_RUN=false
APIFY_POLL_INTERVAL_SECONDS=20

# Example donors only. Used as fallback when automatic donor search is not enough.
SEED_DONORS=expert1,expert2,expert3

# Main source for automatic donor discovery.
SIMILAR_DONOR_KEYWORDS=ИИ для бизнеса,автоматизация бизнеса,автоворонка продаж,amocrm,онлайн школа,запуск онлайн школы,инстаграм продажи,лиды из инстаграм,ИИ ассистент,AI эксперт,бизнес процессы,отдел продаж,скрипты продаж,обработка заявок,клиентский сервис,директ менеджер

# Fallback search terms if the seed/similar donor pool is not enough.
DEFAULT_KEYWORDS=автоматизация продаж,продажи в директ,нейросети для бизнеса,чат боты для бизнеса,воронка продаж,CRM для бизнеса,нейропродавец

MIN_DONOR_FOLLOWERS=5000
DONOR_POSTS_LOOKBACK=50

# Scheduler starts counting only after manual button/API run.
AUTO_HUNT_ENABLED=true
AUTO_HUNT_INTERVAL_HOURS=24
AUTO_HUNT_START_ON_BOOT=false
AUTO_HUNT_MAX_DONORS=8
AUTO_HUNT_MAX_COMMENTS_PER_POST=100
AUTO_HUNT_MAX_LEADS=10
COMMENT_FETCH_GROWTH_FACTOR=2
COMMENT_FETCH_HARD_LIMIT=1000

# Local dedupe storage. For production, use a persistent disk or Postgres-backed storage.
DATABASE_PATH=lead_hunter.db
